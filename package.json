{
  "name": "niceentech_product",
  "description": "NICEENTECH 생산관리 시스템",
  "author": "NICEENTECH",
  "private": true,
  "version": "1.3.31",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/JAEDEOK-JO/niceentech-product.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:icons": "node scripts/build-icons.mjs",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev-server\"",
    "build:electron": "node scripts/gen-electron-env.mjs && vite build --base ./",
    "electron:build": "npm run build:electron && electron-builder",
    "electron:build:mac": "npm run build:electron && electron-builder --mac --publish=never",
    "electron:start": "electron .",
    "desktop:publish": "npm run build:electron && electron-builder --win --publish=never --config.directories.output=release"
  },
  "build": {
    "appId": "com.niceentech.product",
    "productName": "NICEENTECH",
    "copyright": "Copyright © 2025 NICEENTECH",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://joxfohziazjhscewifjj.supabase.co/storage/v1/object/public/update/",
        "channel": "latest"
      }
    ]
  },
  "dependencies": {
    "@onesignal/onesignal-vue3": "^2.0.1",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-vue-next": "^0.575.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "concurrently": "^9.1.2",
    "electron": "^36.1.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^8.0.3"
  }
}
