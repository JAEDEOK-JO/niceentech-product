{
  "name": "niceentech_product",
  "description": "NICEENTECH desktop application",
  "author": "NICEENTECH",
  "private": true,
  "version": "0.0.5",
  "main": "electron/main.cjs",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/JAEDEOK-JO/niceentech-product.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "wait-on tcp:5173 && electron .",
    "desktop:dev": "concurrently -k \"npm:dev\" \"npm:electron:dev\"",
    "desktop:build": "npm run build && electron-builder",
    "desktop:publish": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-vue-next": "^0.575.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.niceentech.product",
    "productName": "NICEENTECH",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "JAEDEOK-JO",
        "repo": "niceentech-product",
        "releaseType": "release"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    }
  }
}
